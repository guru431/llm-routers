# Copy this file to .env (same directory) and fill in the token.
# server.py loads this .env at startup via _load_dotenv(); a real environment
# variable of the same name always takes precedence over the file.

# Bearer token — REQUIRED. The server refuses to start without it (exit 2).
# Generate: python -c "import secrets; print('cas-'+secrets.token_hex(16))"
CLAUDE_AGENT_TOKEN=cas-replace-with-your-token

# Optional overrides (defaults shown):
# CLAUDE_AGENT_MODEL=claude-opus-4-8
# CLAUDE_AGENT_PORT=8765
# CLAUDE_AGENT_CACHE=1
# CLAUDE_AGENT_CACHE_SIZE=256
# CLAUDE_AGENT_CACHE_TTL=3600
