# Copy this file to .env (same directory) and fill in the token.
# server.py loads this .env at startup via _load_dotenv(); a real environment
# variable of the same name always takes precedence over the file.
# NOTE: an inline comment AFTER a value is NOT supported — the whole text after
# `=` becomes the value (e.g. `CODEX_AGENT_TOKEN=cas-xxx  # prod` keeps the
# "# prod"). Put comments on their own line only.

# Bearer token for read-only requests — REQUIRED. The server refuses to start
# without it (exit 2). Generate:
#   python -c "import secrets; print('cas-'+secrets.token_hex(16))"
CODEX_AGENT_TOKEN=cas-replace-with-your-token

# SEPARATE bearer token for workspace-write (agentic file-write/exec) requests.
# The transport auth accepts EITHER token, so a request presenting this token
# reaches workspace-write; presenting only CODEX_AGENT_TOKEN stays read-only.
# A workspace-write request must present a token matching this one. If left
# empty/unset, workspace-write is DISABLED (403); read-only keeps working with
# CODEX_AGENT_TOKEN. Use a DISTINCT value so a leaked read-only token cannot
# grant agentic access. Generate as above.
CODEX_AGENT_AGENT_TOKEN=

# Working dir for read-only codex. read-only codex still has full host *read*
# access; this only pins its cwd (relative paths resolve here). If unset, codex
# runs in the server's cwd with whole-host read access (startup warning logged).
# Default = CODEX_AGENT_WORKDIR_ROOT.
# CODEX_AGENT_READ_ROOT=

# Optional overrides (defaults shown):
# CODEX_AGENT_MODEL=gpt-5.5
# CODEX_AGENT_PORT=8766
# CODEX_AGENT_HOST=127.0.0.1
# CODEX_AGENT_DEFAULT_SANDBOX=read-only
# CODEX_AGENT_REASONING=medium
# CODEX_AGENT_MAX_CONCURRENCY=4
# CODEX_AGENT_WORKDIR=             # agent write root (required for workspace-write)
# CODEX_AGENT_WORKDIR_ROOT=        # allowed root for per-request workdir override
